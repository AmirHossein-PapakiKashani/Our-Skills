              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "The variable's ID. Doesn't apply to collection-level variables."
                },
                "key": {
                  "type": "string",
                  "description": "The variable's key (name)."
                },
                "description": {
                  "type": "string",
                  "maxLength": 512,
                  "description": "The variable's description."
                },
                "value": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "integer"
                    }
                  ],
                  "description": "The key's value."
                },
                "disabled": {
                  "type": "boolean",
                  "description": "If true, the variable is not enabled. Doesn't apply to path parameter variables."
                }
              },
              "additionalProperties": false,
              "description": "Information about the variable."
            },
            "description": "A list of the collection's [variables](https://learning.postman.com/docs/sending-requests/variables/variables/). Make certain not to include sensitive information in variables."
          },
