      "collectionId": {
        "type": "string",
        "description": "The collection ID must be in the form <OWNER_ID>-<UUID> (e.g. 12345-33823532ab9e41c9b6fd12d0fd459b8b)."
      },
      "collection": {
        "type": "object",
        "properties": {
          "info": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
