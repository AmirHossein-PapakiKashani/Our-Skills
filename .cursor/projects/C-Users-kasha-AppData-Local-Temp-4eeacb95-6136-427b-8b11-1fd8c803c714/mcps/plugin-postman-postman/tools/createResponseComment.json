{
  "name": "createResponseComment",
  "description": "Creates a comment on a response. To create a reply on an existing comment, include the \\`threadId\\` property in the request body.\n\n**Note:**\n\nThis endpoint accepts a max of 10,000 characters.\n",
  "arguments": {
    "type": "object",
    "properties": {
      "collectionId": {
        "type": "string",
        "description": "The collection's unique ID."
      },
      "responseId": {
        "type": "string",
        "description": "The response's unique ID."
      },
      "body": {
        "type": "string",
        "description": "The contents of the comment."
      },
      "threadId": {
        "type": "integer",
        "description": "The comment's thread ID. To create a reply on an existing comment, include this property."
      },
      "tags": {
        "type": "object",
        "properties": {
          "{{userName}}": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "user",
                "description": "The `user` value."
              },
              "id": {
                "type": "string",
                "description": "The user's ID."
              }
            },
            "required": [
              "type",
              "id"
            ],
            "additionalProperties": false,
            "description": "An object that contains information about the tagged user. The object's name is the user's Postman username. For example, `@user-postman`."
          }
        },
        "additionalProperties": false,
        "description": "Information about users tagged in the `body` comment."
      }
    },
    "required": [
      "collectionId",
      "responseId",
      "body"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "plugin": "postman",
  "marketplace": "cursor-public",
  "pluginId": "2050",
  "marketplaceId": "34"
}