        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\kasha\\.cursor\\hooks\\session-rtl-context.ps1\""
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\kasha\\.cursor\\hooks\\before-submit-rtl.ps1\""
      }
    ],
    "preToolUse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\kasha\\.cursor\\hooks\\rtk-rewrite.ps1\"",
